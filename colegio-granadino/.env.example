# .env.example — Colegio Granadino Inventario
# Copiar a .env.local y completar con valores reales

# ── Vercel Postgres (Dashboard → Storage → Create Database → .env.local) ──
POSTGRES_PRISMA_URL="postgresql://USER:PASS@HOST/DB?pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgresql://USER:PASS@HOST/DB?connect_timeout=15"

# ── NextAuth (generar: openssl rand -base64 32) ──────────────────────────
NEXTAUTH_SECRET="CAMBIAR_POR_SECRETO_REAL_32_CHARS"
NEXTAUTH_URL="http://localhost:3000"

# ── Google OAuth (console.cloud.google.com → Credentials) ────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Vercel Blob (Dashboard → Storage → Blob → Connect) ───────────────────
BLOB_READ_WRITE_TOKEN=""
